    ).strip()
    lang_raw = input("Languages (comma separated, e.g. TypeScript,Python): ").strip()
    fw_raw = input("Frameworks (comma separated, e.g. React,FastAPI): ").strip()
    test_raw = input("Testing tools (comma separated, e.g. vitest,pytest): ").strip()
    lint_raw = input("Lint/format tools (comma separated, e.g. eslint,prettier,ruff): ").strip()
    compliance_raw = input("Compliance packs (optional comma separated: pci-dss,hipaa,soc2,gdpr,ccpa,iso27001): ").strip()

    agents = [a.strip() for a in agents_raw.split(",") if a.strip()] if agents_raw else list(DEFAULT_AGENTS)
    languages = [l.strip() for l in lang_raw.split(",") if l.strip()]
    frameworks = [f.strip() for f in fw_raw.split(",") if f.strip()]
    tests = [t.strip() for t in test_raw.split(",") if t.strip()]
    linting = [l.strip() for l in lint_raw.split(",") if l.strip()]

    preset_data = STACK_PRESETS.get(preset, {})
    if preset and not preset_data:
        print(f"Unknown preset '{preset}'. Continuing without preset.")

    languages = merge_unique(preset_data.get("languages", []), languages)
    frameworks = merge_unique(preset_data.get("frameworks", []), frameworks)
    tests = merge_unique(preset_data.get("tests", []), tests)
    linting = merge_unique(preset_data.get("linting", []), linting)

    stack_hint = {"frameworks": frameworks, "languages": languages}
    app_intent, app_intent_display, app_data = resolve_app_blueprint(app_intent_input, stack_hint)
    selected_compliance = parse_compliance_input(compliance_raw)
    compliance_packs = resolve_compliance_packs(app_intent_display, selected_compliance)

    suggestions = []
    suggestions.extend(preset_data.get("suggestions", []))
    suggestions.extend(app_data.get("suggestions", []))
    for pack in compliance_packs:
        suggestions.append(f"Compliance focus ({pack['name']}): {', '.join(pack.get('checks', [])[:2])}")
    lset = {x.lower() for x in languages}
    fset = {x.lower() for x in frameworks}

    if "typescript" in lset and "react" in fset:
        suggestions.append("Use eslint + prettier + type-aware strict tsconfig.")
        suggestions.append("Prefer vitest + testing-library for unit/integration tests.")
    if "python" in lset:
        suggestions.append("Use ruff + mypy + pytest with pre-commit hooks.")
    if "fastapi" in fset:
        suggestions.append("Add pydantic validation and contract tests for API schemas.")
    if app_intent == "chatbot":
        suggestions.append("Track conversation quality metrics (groundedness, relevance, safety).")
        if "react" in fset or "next.js" in fset:
            suggestions.append("Design a streaming chat UI with retry/fallback and transcript persistence.")
        if "express" in fset or "nestjs" in fset or "fastify" in fset:
            suggestions.append("Isolate model provider adapters behind interfaces for easy vendor switching.")
        if "laravel" in fset:
            suggestions.append("Use queued jobs for async model/retrieval calls and persist session context.")
        if "python" in lset or "fastapi" in fset or "django" in fset:
            suggestions.append("Protect model endpoints with per-tenant quotas and structured prompt telemetry.")
    if app_intent == "crm":
        suggestions.append("Define account/contact/opportunity schemas and lifecycle transitions explicitly.")
        suggestions.append("Require permission checks and audit trails on every write path.")

    suggestions = merge_unique([], suggestions)

    return {
        "target_os": os_value,
        "preset": preset,
        "app_intent": app_intent,
        "app_intent_input": app_intent_display,
        "agents": agents,
        "languages": languages,
        "frameworks": frameworks,
        "tests": tests,
        "linting": linting,
        "compliance_keys": [pack["key"] for pack in compliance_packs],
        "suggestions": suggestions,
